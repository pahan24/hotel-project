<%- include('../../../partials/admin-header') %>

    <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <div class="pb-5 border-b border-gray-200">
            <h3 class="text-2xl leading-6 font-medium text-gray-900 font-serif">
                Customer Inquiries
            </h3>
        </div>

        <div class="mt-8 flex flex-col">
            <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                    <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col"
                                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        Customer</th>
                                    <th scope="col"
                                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        Subject</th>
                                    <th scope="col"
                                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        Message</th>
                                    <th scope="col"
                                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        Status</th>
                                    <th scope="col" class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% if (messages.length===0) { %>
                                    <tr>
                                        <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">No messages
                                            found.</td>
                                    </tr>
                                    <% } else { %>
                                        <% messages.forEach(msg=> { %>
                                            <tr class="<%= !msg.isRead ? 'bg-indigo-50' : '' %>">
                                                <td class="px-6 py-4 whitespace-nowrap">
                                                    <div class="text-sm font-medium text-gray-900">
                                                        <%= msg.name %>
                                                    </div>
                                                    <div class="text-sm text-gray-500"><a
                                                            href="mailto:<%= msg.email %>">
                                                            <%= msg.email %>
                                                        </a></div>
                                                    <div class="text-sm text-gray-500">
                                                        <%= msg.phone %>
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4 text-sm text-gray-900 font-semibold">
                                                    <%= msg.subject %>
                                                </td>
                                                <td class="px-6 py-4 text-sm text-gray-500 max-w-xs break-words">
                                                    <%= msg.message %>
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap">
                                                    <% if (!msg.isRead) { %>
                                                        <span
                                                            class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">New</span>
                                                        <% } else { %>
                                                            <span
                                                                class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Read</span>
                                                            <% } %>
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                                    <% if (!msg.isRead) { %>
                                                        <form action="/admin/messages/read/<%= msg._id %>" method="POST"
                                                            class="inline">
                                                            <button type="submit"
                                                                class="text-indigo-600 hover:text-indigo-900">Mark as
                                                                Read</button>
                                                        </form>
                                                        <% } else { %>
                                                            <span class="text-gray-400 cursor-not-allowed">Read</span>
                                                            <% } %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../../../partials/admin-footer') %>