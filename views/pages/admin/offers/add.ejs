<%- include('../../../partials/admin-header') %>

    <div class="max-w-3xl mx-auto py-6 sm:px-6 lg:px-8">
        <div class="pb-5 border-b border-gray-200">
            <h3 class="text-2xl leading-6 font-medium text-gray-900 font-serif">Add New Offer</h3>
        </div>

        <form class="space-y-8 divide-y divide-gray-200 mt-6" action="/admin/offers/add" method="POST">
            <div class="space-y-6 sm:space-y-5">
                <div class="sm:grid sm:grid-cols-3 sm:gap-4 sm:items-start sm:pt-5">
                    <label for="title" class="block text-sm font-medium text-gray-700 sm:mt-px sm:pt-2"> Offer Title
                    </label>
                    <div class="mt-1 sm:mt-0 sm:col-span-2">
                        <input type="text" name="title" id="title" required
                            class="max-w-lg block w-full shadow-sm focus:ring-gray-900 focus:border-gray-900 sm:max-w-xs sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                    </div>
                </div>

                <div class="sm:grid sm:grid-cols-3 sm:gap-4 sm:items-start sm:border-t sm:border-gray-200 sm:pt-5">
                    <label for="discountDetails" class="block text-sm font-medium text-gray-700 sm:mt-px sm:pt-2">
                        Discount Details </label>
                    <div class="mt-1 sm:mt-0 sm:col-span-2">
                        <input type="text" name="discountDetails" id="discountDetails"
                            placeholder="e.g. 20% Off on Suite Rooms" required
                            class="max-w-lg block w-full shadow-sm focus:ring-gray-900 focus:border-gray-900 sm:max-w-xs sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                    </div>
                </div>

                <div class="sm:grid sm:grid-cols-3 sm:gap-4 sm:items-start sm:border-t sm:border-gray-200 sm:pt-5">
                    <label for="validUntil" class="block text-sm font-medium text-gray-700 sm:mt-px sm:pt-2"> Valid
                        Until Date </label>
                    <div class="mt-1 sm:mt-0 sm:col-span-2">
                        <input type="date" name="validUntil" id="validUntil" required
                            class="max-w-lg block w-full shadow-sm focus:ring-gray-900 focus:border-gray-900 sm:max-w-xs sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                    </div>
                </div>

                <div class="sm:grid sm:grid-cols-3 sm:gap-4 sm:items-start sm:border-t sm:border-gray-200 sm:pt-5">
                    <label for="description" class="block text-sm font-medium text-gray-700 sm:mt-px sm:pt-2"> Terms &
                        Conditions / Description </label>
                    <div class="mt-1 sm:mt-0 sm:col-span-2">
                        <textarea id="description" name="description" rows="5" required
                            class="max-w-lg shadow-sm block w-full focus:ring-gray-900 focus:border-gray-900 sm:text-sm border border-gray-300 rounded-md py-2 px-3"></textarea>
                    </div>
                </div>

                <div class="sm:grid sm:grid-cols-3 sm:gap-4 sm:items-start sm:border-t sm:border-gray-200 sm:pt-5">
                    <div class="sm:col-start-2 sm:col-span-2">
                        <div class="flex items-center">
                            <input id="isActive" name="isActive" type="checkbox" checked
                                class="focus:ring-gray-900 h-4 w-4 text-gray-900 border-gray-300 rounded">
                            <label for="isActive" class="ml-2 block text-sm text-gray-900"> Active </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-5">
                <div class="flex justify-end">
                    <a href="/admin/offers"
                        class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900">Cancel</a>
                    <button type="submit"
                        class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-gray-900 hover:bg-black focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900">Save
                        Offer</button>
                </div>
            </div>
        </form>
    </div>

    <%- include('../../../partials/admin-footer') %>