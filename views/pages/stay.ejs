<%- include('../partials/header') %>

    <!-- Header Banner -->
    <section class="relative pt-32 pb-20 bg-dark text-white text-center">
        <div class="absolute inset-0 z-0 opacity-40">
            <img src="https://images.unsplash.com/photo-1578683010236-d716f9a3f461?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80"
                alt="Rooms Banner" class="w-full h-full object-cover" />
        </div>
        <div class="relative z-10 max-w-4xl mx-auto px-4 fade-up-enter mt-10">
            <h1 class="text-5xl md:text-6xl font-serif mb-6">Our Accommodations</h1>
            <p class="text-xl font-light text-gray-300">Sanctuaries of peace and heritage, designed for the modern
                traveler.</p>
        </div>
    </section>

    <!-- Rooms Listing -->
    <section class="py-20 bg-[#faf9f6]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <% if (rooms.length===0) { %>
                <div class="text-center py-20">
                    <h3 class="text-2xl font-serif text-dark mb-4">No rooms available currently.</h3>
                    <p class="text-gray-500">Please check back later or contact us directly.</p>
                </div>
                <% } else { %>
                    <div class="space-y-16">
                        <% rooms.forEach((room, index)=> { %>
                            <div
                                class="flex flex-col md:flex-row bg-white rounded-lg overflow-hidden shadow-2xl fade-up-enter <%= index % 2 !== 0 ? 'md:flex-row-reverse' : '' %>">

                                <!-- Image Column -->
                                <div class="md:w-1/2 relative group overflow-hidden min-h-[300px] md:min-h-[400px]">
                                    <img src="<%= room.images && room.images.length > 0 ? room.images[0] : 'https://images.unsplash.com/photo-1611892440504-42a792e24d32?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80' %>"
                                        alt="<%= room.name %>"
                                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                                </div>

                                <!-- Content Column -->
                                <div class="md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
                                    <span class="text-gold uppercase tracking-widest text-xs font-semibold mb-2 block">
                                        <%= room.type %>
                                    </span>
                                    <h2 class="text-3xl md:text-4xl font-serif text-dark mb-4">
                                        <%= room.name %>
                                    </h2>

                                    <p class="text-gray-600 mb-6 leading-relaxed">
                                        <%= room.description %>
                                    </p>

                                    <!-- Facilities -->
                                    <div class="mb-8 border-t border-gray-100 pt-6">
                                        <h4 class="text-sm uppercase tracking-widest text-gray-400 mb-4 font-semibold">
                                            Room Amenities</h4>
                                        <ul class="grid grid-cols-2 gap-y-2 text-sm text-gray-700">
                                            <% room.facilities.forEach(facility=> { %>
                                                <li class="flex items-center">
                                                    <svg class="w-4 h-4 text-gold mr-2" fill="none"
                                                        stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                    </svg>
                                                    <%= facility %>
                                                </li>
                                                <% }) %>
                                        </ul>
                                    </div>

                                    <div
                                        class="mt-auto flex flex-col sm:flex-row items-baseline sm:items-center justify-between border-t border-gray-100 pt-6">
                                        <div class="mb-4 sm:mb-0">
                                            <p class="text-gray-500 text-sm">Starting from</p>
                                            <p class="text-2xl font-bold text-dark">$<%= room.pricePerNight %> <span
                                                        class="text-sm font-normal text-gray-500">/ night</span></p>
                                        </div>
                                        <a href="/stay/book/<%= room._id %>"
                                            class="btn-gold px-8 py-3 rounded-full text-sm font-bold tracking-wider uppercase text-center w-full sm:w-auto transition-transform transform hover:-translate-y-1 shadow-lg shadow-gold/30">
                                            Reserve Room
                                        </a>
                                    </div>
                                </div>

                            </div>
                            <% }) %>
                    </div>
                    <% } %>
        </div>
    </section>

    <%- include('../partials/footer') %>