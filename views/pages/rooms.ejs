<%- include('../partials/header', { title: 'Rooms & Suites' }) %>
<section class="max-w-7xl mx-auto px-4 py-14">
  <h1 class="text-4xl font-serif mb-6">Rooms & Suites</h1>
  <form method="get" class="grid md:grid-cols-4 gap-3 bg-white p-4 rounded-xl shadow mb-8">
    <select name="type" class="input"><option value="">All Types</option><% types.forEach((t) => { %><option value="<%= t %>" <%= filters.type===t ? 'selected':'' %>><%= t %></option><% }) %></select>
    <input name="maxPrice" value="<%= filters.maxPrice || '' %>" type="number" class="input" placeholder="Max Price" />
    <label class="flex items-center gap-2"><input type="checkbox" name="available" value="true" <%= filters.available==='true'?'checked':'' %> /> Available only</label>
    <button class="bg-slate-900 text-white rounded px-4">Filter</button>
  </form>
  <div class="grid md:grid-cols-2 gap-6">
    <% rooms.forEach((room)=> { %>
      <article class="bg-white rounded-xl shadow overflow-hidden">
        <img src="<%= room.image %>" class="h-56 w-full object-cover" />
        <div class="p-5">
          <h2 class="text-2xl font-semibold"><%= room.name %></h2>
          <p><%= room.description %></p>
          <p class="my-2 text-sm">Facilities: <%= room.facilities.join(', ') %></p>
          <p class="font-bold">USD <%= room.price %>/night</p>
          <a href="/#booking" class="inline-block mt-3 bg-amber-500 px-4 py-2 rounded">Book Now</a>
        </div>
      </article>
    <% }) %>
  </div>
</section>
<%- include('../partials/footer') %>
