<%- include('../partials/header', { title: 'Luxury Hotel in Kandy' }) %>
<section class="hero min-h-[78vh] bg-cover bg-center flex items-center" style="background-image:url('https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=1800&auto=format&fit=crop')">
  <div class="max-w-7xl mx-auto px-4 text-white animate-fade-in-up">
    <p class="uppercase tracking-[0.4em] text-sm">Sri Lanka · Kandy</p>
    <h1 class="text-5xl md:text-7xl font-serif my-6">Where Colonial Grace Meets Highland Calm</h1>
    <a href="#booking" class="inline-block bg-amber-500 text-slate-900 px-6 py-3 rounded-full font-semibold">Book Now</a>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 py-16 grid md:grid-cols-3 gap-6">
  <div class="card">Infinity pool overlooking misty valley</div>
  <div class="card">Award-winning restaurant and tea lounge</div>
  <div class="card">Spa, event spaces and concierge experiences</div>
</section>

<section class="max-w-7xl mx-auto px-4 py-16">
  <h2 class="text-3xl font-serif mb-8">Featured Rooms</h2>
  <div class="grid md:grid-cols-3 gap-6">
    <% featuredRooms.forEach((room) => { %>
      <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:scale-[1.01] transition">
        <img src="<%= room.image %>" alt="<%= room.name %>" class="h-52 w-full object-cover" />
        <div class="p-5">
          <h3 class="text-xl font-semibold"><%= room.name %></h3>
          <p class="text-slate-600"><%= room.description %></p>
          <p class="mt-3 font-bold">USD <%= room.price %> / night</p>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section id="booking" class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl p-8">
  <h2 class="text-3xl font-serif mb-4">Reserve Your Stay</h2>
  <form action="/bookings" method="post" class="grid md:grid-cols-2 gap-4">
    <input class="input" name="customerName" placeholder="Full Name" required />
    <input class="input" type="email" name="email" placeholder="Email" required />
    <input class="input" name="phone" placeholder="Phone" required />
    <input class="input" type="text" name="roomType" placeholder="Room Type" required />
    <input class="input" type="date" name="checkIn" required />
    <input class="input" type="date" name="checkOut" required />
    <textarea class="input md:col-span-2" name="specialRequests" placeholder="Special requests"></textarea>
    <button class="bg-slate-900 text-white rounded-lg py-3 md:col-span-2">Confirm Booking</button>
  </form>
</section>

<section class="max-w-7xl mx-auto px-4 py-16 grid md:grid-cols-2 gap-8">
  <div>
    <h2 class="text-3xl font-serif mb-4">Special Offers</h2>
    <% offers.forEach((offer) => { %><div class="bg-amber-50 p-4 rounded mb-3"><h4 class="font-semibold"><%= offer.title %></h4><p><%= offer.details %></p></div><% }) %>
  </div>
  <div>
    <h2 class="text-3xl font-serif mb-4">Guest Testimonials</h2>
    <% testimonials.forEach((item) => { %><blockquote class="bg-white p-4 rounded mb-3 shadow"><p>“<%= item.text %>”</p><footer class="mt-2 text-sm">— <%= item.name %></footer></blockquote><% }) %>
  </div>
</section>
<%- include('../partials/footer') %>
