<%- include('../partials/header') %>

    <section class="relative pt-32 pb-20 bg-dark text-white text-center">
        <div class="absolute inset-0 z-0 opacity-40">
            <img src="https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80"
                alt="Contact Banner" class="w-full h-full object-cover" />
        </div>
        <div class="relative z-10 max-w-4xl mx-auto px-4 fade-up-enter mt-10">
            <h1 class="text-5xl md:text-6xl font-serif mb-6">Connect With Us</h1>
            <p class="text-xl font-light text-gray-300">We anticipate your arrival. Let us assist with your inquiries.
            </p>
        </div>
    </section>

    <section class="py-20 bg-[#faf9f6]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <% if (success) { %>
                <div class="max-w-3xl mx-auto mb-10 bg-green-50 border-l-4 border-green-400 p-4 fade-up-enter">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd"
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                    clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-green-700">
                                Thank you for your message. We have received your inquiry and will respond to you
                                shortly.
                            </p>
                        </div>
                    </div>
                </div>
                <% } %>

                    <div class="flex flex-col lg:flex-row gap-16 fade-up-enter">

                        <!-- Contact Info -->
                        <div class="lg:w-1/3 space-y-10">
                            <div>
                                <h3 class="text-gold uppercase tracking-widest text-sm font-semibold mb-3">Address</h3>
                                <p class="text-gray-700 leading-relaxed">
                                    The Grove Kandy Estate<br>
                                    123 Heritage Way,<br>
                                    Kandy 20000,<br>
                                    Sri Lanka
                                </p>
                            </div>
                            <div>
                                <h3 class="text-gold uppercase tracking-widest text-sm font-semibold mb-3">Direct
                                    Contact</h3>
                                <p class="text-gray-700 mb-2"><strong>Reservations:</strong> +94 81 234 5678</p>
                                <p class="text-gray-700 mb-2"><strong>Front Desk:</strong> +94 81 234 5679</p>
                                <a href="mailto:reservations@thegrovekandy.com"
                                    class="text-dark hover:text-gold transition-colors block mt-4 border-b border-gold w-max pb-1">reservations@thegrovekandy.com</a>
                            </div>
                        </div>

                        <!-- Contact Form -->
                        <div class="lg:w-2/3">
                            <div class="bg-white p-8 md:p-12 rounded-xl shadow-xl border border-gray-100">
                                <h2 class="text-3xl font-serif text-dark mb-8">Send an Inquiry</h2>

                                <form action="/api/contact" method="POST" class="space-y-6">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full
                                                Name</label>
                                            <input type="text" id="name" name="name" required
                                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-gold focus:border-gold transition-colors">
                                        </div>
                                        <div>
                                            <label for="email"
                                                class="block text-sm font-medium text-gray-700 mb-1">Email
                                                Address</label>
                                            <input type="email" id="email" name="email" required
                                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-gold focus:border-gold transition-colors">
                                        </div>
                                    </div>

                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            <label for="phone"
                                                class="block text-sm font-medium text-gray-700 mb-1">Phone
                                                Number</label>
                                            <input type="tel" id="phone" name="phone"
                                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-gold focus:border-gold transition-colors">
                                        </div>
                                        <div>
                                            <label for="subject"
                                                class="block text-sm font-medium text-gray-700 mb-1">Inquiry
                                                Subject</label>
                                            <input type="text" id="subject" name="subject"
                                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-gold focus:border-gold transition-colors">
                                        </div>
                                    </div>

                                    <div>
                                        <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Your
                                            Message</label>
                                        <textarea id="message" name="message" rows="5" required
                                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-gold focus:border-gold transition-colors"></textarea>
                                    </div>

                                    <button type="submit"
                                        class="btn-gold px-8 py-4 rounded-lg text-sm font-bold tracking-wider uppercase shadow-xl hover:shadow-gold/50 transition-all inline-block">
                                        Send Message
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
        </div>
    </section>

    <!-- Read Subject from URL if present -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const subject = urlParams.get('subject');
            if (subject) {
                document.getElementById('subject').value = subject;
            }
        });
    </script>

    <%- include('../partials/footer') %>