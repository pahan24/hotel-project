<%- include('../partials/header', { title: 'Contact' }) %>
<section class="max-w-7xl mx-auto px-4 py-14 grid md:grid-cols-2 gap-8">
  <div>
    <h1 class="text-4xl font-serif mb-4">Contact Us</h1>
    <p>20 Lady Gordon's Drive, Kandy, Sri Lanka</p>
    <p class="mt-2">Phone: <%= site.phone %><br/>Email: <%= site.email %></p>
    <iframe class="mt-4 w-full h-72 rounded-xl" src="https://www.google.com/maps?q=kandy%20sri%20lanka&output=embed"></iframe>
  </div>
  <form action="/contact" method="post" class="bg-white rounded-xl p-6 shadow grid gap-3">
    <input class="input" name="name" placeholder="Name" required />
    <input class="input" name="email" type="email" placeholder="Email" required />
    <input class="input" name="subject" placeholder="Subject" required />
    <textarea class="input" rows="5" name="message" placeholder="Message"></textarea>
    <button class="bg-slate-900 text-white py-2 rounded">Send Message</button>
  </form>
</section>
<%- include('../partials/footer') %>
