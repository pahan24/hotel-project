<%- include('../partials/header', { title: 'Restaurant & Dining' }) %>
<section class="max-w-7xl mx-auto px-4 py-14">
  <h1 class="text-4xl font-serif mb-8">Restaurant & Dining</h1>
  <div class="grid md:grid-cols-3 gap-6">
    <% menu.forEach((dish) => { %>
      <article class="bg-white shadow rounded-xl overflow-hidden">
        <img src="<%= dish.image %>" class="h-48 w-full object-cover" />
        <div class="p-4"><h3 class="font-semibold"><%= dish.title %></h3><p><%= dish.description %></p><p class="font-bold mt-2">USD <%= dish.price %></p></div>
      </article>
    <% }) %>
  </div>
  <div class="mt-12 bg-white p-6 rounded-xl shadow max-w-2xl">
    <h2 class="text-2xl font-serif mb-3">Reserve a Table</h2>
    <form action="/dining/table-booking" method="post" class="grid md:grid-cols-2 gap-3">
      <input name="name" class="input" placeholder="Name" required /><input type="email" name="email" class="input" placeholder="Email" required />
      <input name="phone" class="input" placeholder="Phone" required /><input type="date" name="date" class="input" required />
      <input name="time" class="input" placeholder="Time" required /><input type="number" name="guests" class="input" placeholder="Guests" required />
      <textarea name="notes" class="input md:col-span-2" placeholder="Notes"></textarea>
      <button class="bg-slate-900 text-white py-2 rounded md:col-span-2">Book Table</button>
    </form>
  </div>
</section>
<%- include('../partials/footer') %>
