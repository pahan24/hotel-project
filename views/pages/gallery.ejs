<%- include('../partials/header', { title: 'Gallery' }) %>
<section class="max-w-7xl mx-auto px-4 py-14">
  <h1 class="text-4xl font-serif mb-8">Gallery</h1>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
    <% galleryImages.forEach((img) => { %>
      <img src="<%= img %>" class="lightbox-trigger h-48 md:h-64 w-full object-cover rounded-xl cursor-pointer" />
    <% }) %>
  </div>
</section>
<div id="lightbox" class="hidden fixed inset-0 bg-black/80 items-center justify-center z-50"><img id="lightbox-img" class="max-h-[80vh] rounded-xl" /></div>
<%- include('../partials/footer') %>
