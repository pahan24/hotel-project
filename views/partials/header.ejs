<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Luxury hillside retreat in Kandy, Sri Lanka. Book elegant rooms, dining, events and curated experiences at The Grove Kandy." />
  <meta name="keywords" content="Kandy hotel, luxury Sri Lanka, The Grove Kandy, hotel booking" />
  <meta property="og:title" content="The Grove Kandy" />
  <meta property="og:description" content="Luxury hotel in Sri Lanka with elegant rooms, dining and events." />
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="/js/main.js"></script>
  <link rel="stylesheet" href="/css/styles.css" />
  <title><%= title %> | The Grove Kandy</title>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Hotel",
      "name": "The Grove Kandy",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Kandy",
        "addressCountry": "Sri Lanka"
      },
      "telephone": "+94 81 223 7788",
      "url": "https://thegrovekandy.com"
    }
  </script>
</head>
<body class="bg-stone-50 text-slate-800 scroll-smooth">
  <header class="sticky top-0 z-50 bg-slate-950/95 text-white shadow-lg">
    <nav class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
      <a href="/" class="font-serif text-2xl tracking-wide">The Grove Kandy</a>
      <div class="flex gap-4 text-sm md:text-base">
        <a href="/" class="hover:text-amber-300">Home</a>
        <a href="/rooms" class="hover:text-amber-300">Rooms</a>
        <a href="/dining" class="hover:text-amber-300">Dining</a>
        <a href="/gallery" class="hover:text-amber-300">Gallery</a>
        <a href="/contact" class="hover:text-amber-300">Contact</a>
      </div>
    </nav>
  </header>
