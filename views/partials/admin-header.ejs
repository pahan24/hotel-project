<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Grove Kandy Admin - <%= typeof title !== 'undefined' ? title : 'Login' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
        h1, h2, h3, h4, .font-serif { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="text-gray-800 antialiased h-screen flex flex-col">
    <% if (admin) { %>
        <nav class="bg-gray-900 text-white shadow-lg">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <div class="flex items-center">
                        <div class="flex-shrink-0 font-serif text-xl tracking-wider">
                            The Grove Admin
                        </div>
                        <div class="hidden md:block">
                            <div class="ml-10 flex items-baseline space-x-4">
                                <a href="/admin/dashboard" class="hover:bg-gray-700 px-3 py-2 rounded-md text-sm font-medium">Dashboard</a>
                                <a href="/admin/rooms" class="hover:bg-gray-700 px-3 py-2 rounded-md text-sm font-medium">Rooms</a>
                                <a href="/admin/bookings" class="hover:bg-gray-700 px-3 py-2 rounded-md text-sm font-medium">Bookings</a>
                                <a href="/admin/logout" class="hover:bg-red-700 bg-red-600 px-3 py-2 rounded-md text-sm font-medium ml-4">Logout</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    <% } %>
    <main class="flex-grow">
