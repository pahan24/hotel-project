<%- include('../partials/header', { title: 'Manage Content' }) %>
<section class="max-w-5xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-serif mb-6">Website Content JSON Editor</h1>
  <p class="mb-4 text-sm text-slate-600">Use valid JSON arrays to update offers, testimonials, menu, and gallery content.</p>
  <form action="/admin/content" method="post" class="grid gap-4">
    <label>Offers<textarea class="input h-40" name="offers"><%= JSON.stringify(offers, null, 2) %></textarea></label>
    <label>Testimonials<textarea class="input h-40" name="testimonials"><%= JSON.stringify(testimonials, null, 2) %></textarea></label>
    <label>Menu<textarea class="input h-40" name="menu"><%= JSON.stringify(menu, null, 2) %></textarea></label>
    <label>Gallery<textarea class="input h-40" name="gallery"><%= JSON.stringify(gallery, null, 2) %></textarea></label>
    <button class="bg-slate-900 text-white py-2 rounded">Save Content</button>
  </form>
</section>
<%- include('../partials/footer') %>
