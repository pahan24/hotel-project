<%- include('../partials/header', { title: 'Manage Rooms' }) %>
<section class="max-w-7xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-serif mb-6">Room Management</h1>
  <form method="post" action="/admin/rooms" class="bg-white p-4 rounded-xl shadow grid md:grid-cols-2 gap-3 mb-8">
    <input class="input" name="name" placeholder="Room name" required />
    <input class="input" name="type" placeholder="Type" required />
    <input class="input" name="price" type="number" placeholder="Price" required />
    <input class="input" name="capacity" type="number" placeholder="Capacity" />
    <input class="input md:col-span-2" name="image" placeholder="Image URL" />
    <textarea class="input md:col-span-2" name="description" placeholder="Description"></textarea>
    <input class="input md:col-span-2" name="facilities" placeholder="Facilities comma-separated" />
    <label><input type="checkbox" name="featured" /> Featured</label>
    <label><input type="checkbox" name="available" checked /> Available</label>
    <button class="bg-slate-900 text-white rounded py-2 md:col-span-2">Add Room</button>
  </form>

  <% rooms.forEach((room) => { %>
    <form method="post" action="/admin/rooms/<%= room._id %>/update" class="bg-white p-4 rounded-xl shadow grid md:grid-cols-2 gap-3 mb-4">
      <input class="input" name="name" value="<%= room.name %>" />
      <input class="input" name="type" value="<%= room.type %>" />
      <input class="input" name="price" type="number" value="<%= room.price %>" />
      <input class="input" name="capacity" type="number" value="<%= room.capacity %>" />
      <input class="input md:col-span-2" name="image" value="<%= room.image %>" />
      <textarea class="input md:col-span-2" name="description"><%= room.description %></textarea>
      <input class="input md:col-span-2" name="facilities" value="<%= room.facilities.join(', ') %>" />
      <label><input type="checkbox" name="featured" <%= room.featured ? 'checked':'' %> /> Featured</label>
      <label><input type="checkbox" name="available" <%= room.available ? 'checked':'' %> /> Available</label>
      <button class="bg-amber-500 rounded py-2">Update</button>
      <button formaction="/admin/rooms/<%= room._id %>/delete" class="bg-red-600 text-white rounded py-2">Delete</button>
    </form>
  <% }) %>
</section>
<%- include('../partials/footer') %>
