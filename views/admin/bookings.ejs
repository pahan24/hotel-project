<%- include('../partials/header', { title: 'Manage Bookings' }) %>
<section class="max-w-7xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-serif mb-6">Bookings</h1>
  <div class="space-y-4">
    <% bookings.forEach((booking)=> { %>
      <article class="bg-white p-4 rounded-xl shadow flex flex-wrap justify-between gap-4">
        <div><h3 class="font-semibold"><%= booking.customerName %> - <%= booking.roomType %></h3><p><%= booking.email %> | <%= booking.phone %></p><p>Status: <strong><%= booking.status %></strong></p></div>
        <div class="flex gap-2">
          <form method="post" action="/admin/bookings/<%= booking._id %>/status" class="flex gap-2">
            <select name="status" class="input"><option>Pending</option><option>Confirmed</option><option>Checked-In</option><option>Completed</option><option>Cancelled</option></select>
            <button class="bg-amber-500 px-3 rounded">Update</button>
          </form>
          <form method="post" action="/admin/bookings/<%= booking._id %>/delete"><button class="bg-red-600 text-white px-3 rounded">Cancel/Delete</button></form>
          <% if (booking.receiptPath) { %><a href="<%= booking.receiptPath %>" class="underline">Receipt</a><% } %>
        </div>
      </article>
    <% }) %>
  </div>
</section>
<%- include('../partials/footer') %>
