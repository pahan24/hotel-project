<%- include('../partials/header', { title: 'Admin Dashboard' }) %>
<section class="max-w-7xl mx-auto px-4 py-12">
  <div class="flex justify-between items-center"><h1 class="text-4xl font-serif">Dashboard</h1>
    <form action="/admin/logout" method="post"><button class="bg-slate-900 text-white px-4 py-2 rounded">Logout</button></form></div>
  <div class="grid md:grid-cols-4 gap-4 my-6">
    <div class="card">Rooms: <strong><%= rooms.length %></strong></div>
    <div class="card">Bookings: <strong><%= bookings.length %></strong></div>
    <div class="card">Table Reservations: <strong><%= tables.length %></strong></div>
    <div class="card">Subscribers: <strong><%= subscribers %></strong></div>
  </div>
  <div class="flex gap-3 mb-6"><a href="/admin/bookings" class="underline">Manage Bookings</a><a href="/admin/rooms" class="underline">Manage Rooms</a><a href="/admin/content" class="underline">Manage Content</a></div>
</section>
<%- include('../partials/footer') %>
