<%- include('../partials/header', { title: 'Admin Login' }) %>
<section class="max-w-md mx-auto py-20 px-4">
  <form method="post" class="bg-white p-8 rounded-xl shadow">
    <h1 class="text-3xl font-serif mb-5">Admin Login</h1>
    <% if (error) { %><p class="text-red-600"><%= error %></p><% } %>
    <input name="username" class="input mb-3" placeholder="Username" required />
    <input name="password" type="password" class="input mb-3" placeholder="Password" required />
    <button class="w-full bg-slate-900 text-white py-2 rounded">Login</button>
  </form>
</section>
<%- include('../partials/footer') %>
